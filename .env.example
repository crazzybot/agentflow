ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...        # optional — enables real web search (https://tavily.com)
PLANNER_MODEL=claude-sonnet-5
AGENT_MODEL=claude-sonnet-5
TASK_TIMEOUT_MS=30000
TASK_MAX_RETRIES=3
TASK_MAX_TOKENS=4096
MANIFESTS_DIR=manifests
ENABLE_DECOMPOSER=true          # set to false to skip per-subtask decomposition
AGENT_THINKING_EFFORT=high  # global extended-thinking effort (low/medium/high/xhigh/max); "" to disable; manifest value takes precedence
