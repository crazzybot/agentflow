    "/api/runs/{run_id}/artifacts/{artifact_id}": {
      "get": {
        "summary": "Get Run Artifact Content",
        "operationId": "get_run_artifact_content_api_runs__run_id__artifacts__artifact_id__get",
        "parameters": [
          {
            "name": "run_id",
