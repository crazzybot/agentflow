@host = http://localhost:8001

###

GET {{host}}/health HTTP/1.1
Accept: application/json

###

# @name submit_task
POST {{host}}/api/runs HTTP/1.1
Content-Type: application/json

{
    "task": "Implement a simple MCP server that can load historical stock prices.",
    "context": {
        "project": "mcp-sample",
        "language": "Python",
        "dependency_management": "uv"
    },
    "budget_usd": 3.0
}

