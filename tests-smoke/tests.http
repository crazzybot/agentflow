@host = http://localhost:8001

###

GET {{host}}/health HTTP/1.1
Accept: application/json

###

# @name submit_task
POST {{host}}/api/run HTTP/1.1
Content-Type: application/json

{
    "task": "Include event specific rendering to the event details panel, currently it shows only common metadata and complete JSON content, add message specific controls, e.g. for tool call add a section that shows inoput arguments, also for bash_exec tool instead of generic argument rendering render bash command as a code block.",
    "context": {
        "project": "agentflow-trace-viewer",
        "language": "Typescript",
        "tooling": "vite",
        "framework": "react",
        "type": "web, spa"
    },
    "budget_usd": 3.0
}

